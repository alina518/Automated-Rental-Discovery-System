# =========================
# SEARCH / API KEYS
# =========================
SEARCH_API_KEY=your_serper_api_key_here
GOOGLE_API_KEY=your_google_maps_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# =========================
# OFFICE LOCATION
# Use either OFFICE_ADDR
# OR OFFICE_LAT + OFFICE_LNG
# =========================
OFFICE_ADDR=REVA University, Bengaluru

# OFFICE_LAT=13.1166
# OFFICE_LNG=77.6344

# =========================
# TWILIO / WHATSAPP
# =========================
TWILIO_SID=your_twilio_account_sid
TWILIO_TOKEN=your_twilio_auth_token
YOUR_WHATSAPP=whatsapp:+911234567890

# Twilio sandbox sender is already hardcoded in code as:
# whatsapp:+14155238886

# =========================
# MYSQL
# =========================
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=flat_finder
MYSQL_PORT=3306
